# =============================================================================
# MWPanel - konfiguracja Docker
# Skopiuj ten plik jako .env i uzupełnij wartościami
# =============================================================================

# =============================================================================
# WYMAGANE - bez tych wartości aplikacja nie uruchomi się
# =============================================================================

# Hasło do bazy PostgreSQL
DB_PASSWORD=zmien_na_silne_haslo

# Klucz JWT / szyfrowania — wygeneruj: openssl rand -hex 32
SECRET_KEY=zmien_na_losowy_klucz_openssl_rand_hex_32

# =============================================================================
# Baza danych (opcjonalnie zmienić domyślne wartości)
# =============================================================================
DB_NAME=real_estate_monitor
DB_USER=realestate

# =============================================================================
# Port frontendu (domyślnie 80)
# =============================================================================
FRONTEND_PORT=80

# =============================================================================
# Logowanie
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# WhatsApp Business API (opcjonalnie)
# =============================================================================
# WA_TOKEN=
# WA_PHONE_NUMBER_ID=
# WA_TO=

# =============================================================================
# Email SMTP (opcjonalnie)
# =============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=twoj@email.com
# SMTP_PASS=haslo_aplikacji
# FROM_EMAIL=noreply@twojadomena.pl

# =============================================================================
# Telegram (opcjonalnie)
# =============================================================================
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# =============================================================================
# Slack Webhook (opcjonalnie)
# =============================================================================
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# =============================================================================
# Google Maps API (opcjonalnie — do geokodowania)
# =============================================================================
# GOOGLE_MAPS_API_KEY=
