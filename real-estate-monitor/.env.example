# =============================================================================
# Konfiguracja Real Estate Monitor
# =============================================================================

# Skopiuj ten plik jako .env i uzupełnij własnymi wartościami

# =============================================================================
# Baza Danych PostgreSQL
# =============================================================================
DATABASE_URL=postgresql+asyncpg://realestate:password@localhost:5432/real_estate_monitor
DATABASE_URL_SYNC=postgresql://realestate:password@localhost:5432/real_estate_monitor

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# API
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Wygeneruj silny klucz: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-in-production

# =============================================================================
# Celery (Zadania w tle)
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# =============================================================================
# Google Maps API (opcjonalnie)
# Pobierz klucz: https://developers.google.com/maps/documentation/javascript/get-api-key
# =============================================================================
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# =============================================================================
# WhatsApp Business API (opcjonalnie)
# =============================================================================
# WHATSAPP_API_KEY=your-whatsapp-api-key
# WHATSAPP_PHONE_ID=your-phone-id
# WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id

# =============================================================================
# Email SMTP (opcjonalnie)
# =============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# =============================================================================
# Slack Webhook (opcjonalnie)
# =============================================================================
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# =============================================================================
# Facebook/Instagram Ads API (opcjonalnie)
# =============================================================================
# FACEBOOK_APP_ID=your-app-id
# FACEBOOK_APP_SECRET=your-app-secret
# FACEBOOK_ACCESS_TOKEN=your-access-token

# =============================================================================
# AI/OpenAI (opcjonalnie)
# =============================================================================
# OPENAI_API_KEY=your-openai-api-key

# =============================================================================
# Monitoring i Logowanie
# =============================================================================
LOG_LEVEL=INFO
SENTRY_DSN=  # Opcjonalnie dla Sentry
